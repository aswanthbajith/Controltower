# CONTROLTOWER v2.0 — Environment configuration template
# Copy this file to .env and fill in the real values.
# DO NOT commit .env to source control (.gitignore excludes it).

# -----------------------------------------------------------------------
# General
# -----------------------------------------------------------------------
CONTROLTOWER_ENV=local
CONTROLTOWER_LOG_LEVEL=INFO
CONTROLTOWER_PROJECT_ROOT=.
CONTROLTOWER_DATABASE_DIR=databases
CONTROLTOWER_CHROMA_DIR=databases/chroma_db
CONTROLTOWER_TRACKER_DB=databases/tracker.db
CONTROLTOWER_PROFILE_JSON_DIR=data/profile_jsons
CONTROLTOWER_COMPANY_RESEARCH_DIR=data/company_research
CONTROLTOWER_COMPANY_TARGETS_PATH=data/company_targets.yaml

# -----------------------------------------------------------------------
# Local embeddings (nomic-embed-text via Ollama)
# Embeddings remain local per the v2.0 directive.
# -----------------------------------------------------------------------
CONTROLTOWER_OLLAMA_BASE_URL=http://localhost:11434
CONTROLTOWER_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------
# Cloud reasoning provider — Google Gemini
# All generation workloads route through src.core.model_provider.
# Secrets MUST be supplied via environment variables; never commit them.
# Set CLOUD_PROVIDER=fixture for offline / test runs.
# -----------------------------------------------------------------------
CLOUD_PROVIDER=google
CLOUD_API_BASE=https://generativelanguage.googleapis.com
CLOUD_MODEL=gemini-2.5-flash
# Read from os.environ['GEMINI_API_KEY'] ONLY. Never hardcode or commit a key.
GEMINI_API_KEY=
CLOUD_INPUT_COST_PER_1K=0.000075
CLOUD_OUTPUT_COST_PER_1K=0.0003
CLOUD_REQUEST_TIMEOUT_SECONDS=60
CLOUD_MAX_RETRIES=3

# -----------------------------------------------------------------------
# Local retrieval
# -----------------------------------------------------------------------
CONTROLTOWER_CHUNK_SIZE=800
CONTROLTOWER_CHUNK_OVERLAP=150